# API keys for the content generation pipeline (scripts/generate.ts).
# Copy to packages/content/.env and fill in real values. Never commit .env.

# Required. The OpenAI SDK reads this automatically.
OPENAI_API_KEY=

# Optional. Point at any OpenAI-compatible chat completions endpoint. Leave
# unset to use the default OpenAI host (https://api.openai.com/v1).
# OPENAI_BASE_URL=

# Optional. Defaults to gpt-4o-mini. Override per the model IDs your chosen
# endpoint serves.
# LLM_MODEL=

# Optional. When unset (or when --audio is omitted), generate.ts skips audio
# synthesis and only writes the JSON deck; the validator will then flag the
# missing mp3s until you fill them in.
ELEVENLABS_API_KEY=

# Per-target-language voice IDs from the ElevenLabs voice library.
# Pick a native speaker per language; the script picks the one matching the
# deck's target language.
ELEVENLABS_VOICE_ES=
ELEVENLABS_VOICE_ZH=
