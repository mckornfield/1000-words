# Single source of truth for env vars across the workspace.
# Copy to .env (gitignored) and fill in.
#
# Local dev: values are printed by `supabase start`. The "publishable" key is
# the anon key; the "secret" key is the service_role key.

# Browser-exposed: the app talks to Supabase directly using RLS-gated anon key.
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Test-only: never shipped to the browser. Used by RLS integration tests to
# provision/delete throwaway users via the auth admin API.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
